<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Secret Log Pose</title>
    <link rel="stylesheet" href="/css/output.css" />
  </head>
  <body>
    <%- include('partials/navbar', { page: 'Secret Log Pose' }) %>

    <div class="mx-auto px-4 py-8">
      <!-- Request log info alert -->
      <div role="alert" class="alert alert-info mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="h-6 w-6 shrink-0 stroke-current">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span><%= log %></span>
      </div>

      <!-- Destination heading -->
      <div class="mb-8">
        <h1 class="text-5xl font-bold mb-2">Destination Reached</h1>
        <p class="text-lg">The Log Pose has guided the Thousand Sunny to the legendary island of <strong>Laugh Tale</strong> — the final destination at the end of the Grand Line where the One Piece awaits.</p>
      </div>

      <!-- Active crew summary table -->
      <h2 class="text-2xl font-semibold mb-4">Active Crew Members</h2>
      <div class="overflow-x-auto">
        <table class="table table-zebra">
          <thead>
            <tr>
              <th>#</th>
              <th>Name</th>
              <th>Role</th>
              <th>Devil Fruit</th>
              <th>Bounty (Berries)</th>
            </tr>
          </thead>
          <tbody>
            <% for (const member of crew) { %>
              <% if (member.status === "active") { %>
              <tr>
                <td><%= member.id %></td>
                <td><%= member.name %></td>
                <td><%= member.role %></td>
                <td><%= member.devilFruit %></td>
                <td><%= member.bounty.toLocaleString() %></td>
              </tr>
              <% } %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </body>
</html>
