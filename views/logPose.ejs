<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Log Pose - Grand Line Registry</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>⚓</text></svg>" />
    <link rel="stylesheet" href="/css/output.css" />
  </head>
  <body>
    <%- include('partials/navbar', { page: 'Secret Log Pose' }) %>
    <div class="mx-auto px-4 py-8">
      <!-- Request log info alert -->
      <div role="alert" class="alert alert-info mb-6">
        <span><b>LAST REQUEST:</b></span>
        <span><%= log %></span>
      </div>

      <!-- Destination heading -->
      <div class="mb-8">
        <h1 class="text-5xl font-bold mb-2">🗺️ Destination Reached</h1>
        <p class="text-lg">You've made it to the final island at the end of the Grand Line. Only the most determined pirates reach this place. Listed below are the active crew members who completed the journey. </p>
      </div>

      <!-- Active crew summary table -->
      <h2 class="text-2xl font-semibold mb-4">Active Crew Members</h2>
      <div class="overflow-x-auto">
        <table class="table table-zebra">
          <thead>
            <tr>
              <th>#</th>
              <th>Name</th>
              <th>Role</th>
              <th>Devil Fruit</th>
              <th>Bounty (Berries)</th>
            </tr>
          </thead>
          <tbody>
            <% for (const member of crew) { %>
              <% if (member.status === "active") { %>
              <tr>
                <td><%= member.id %></td>
                <td><%= member.name %></td>
                <td><%= member.role %></td>
                <td><%= member.devilFruit %></td>
                <td><%= member.bounty.toLocaleString() %></td>
              </tr>
              <% } %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </body>
</html>
